  ##########################################################
  df %>%
    select(
      BirdID,
      DateTime,
      Latitude,
      Longitude,
      Date
    )
}
############################################################
# 全CSV結合
############################################################
gps <- map_dfr(
  files,
  read_gps
)
############################################################
# 重複削除
############################################################
gps <- gps %>%
  distinct()
############################################################
# 並べ替え
############################################################
gps <- gps %>%
  arrange(
    BirdID,
    DateTime
  )
############################################################
# 各個体・各日最後の記録を採用
############################################################
gps <- gps %>%
  group_by(
    BirdID,
    Date
  ) %>%
  slice_tail(n=1) %>%
  ungroup()
############################################################
# 公開用CSV
############################################################
gps_public <- gps %>%
  transmute(
    BirdID,
    DateTime = format(
      DateTime,
      "%Y-%m-%d %H:%M"
    ),
    Latitude,
    Longitude
  ) %>%
  arrange(
    BirdID,
    DateTime
  )
############################################################
# 保存
############################################################
write_csv(
  gps_public,
  file.path(output_dir,"gps2.csv")
)
############################################################
# 完了
############################################################
cat("\n====================================\n")
cat("変換完了！\n")
cat("CSV数       :",length(files),"\n")
cat("レコード数  :",nrow(gps_public),"\n")
cat("保存先      :",file.path(output_dir,"gps2.csv"),"\n")
cat("====================================\n")############################################################
# Druid GPS（UUID形式）→ gps2.csv
############################################################
library(readr)
library(dplyr)
library(stringr)
library(lubridate)
library(purrr)
############################################################
# フォルダ設定
############################################################
input_dir <- "raw"
output_dir <- "output"
dir.create(output_dir, showWarnings = FALSE)
############################################################
# CSV一覧取得
############################################################
files <- list.files(
  input_dir,
  pattern = "\\.csv$",
  full.names = TRUE
)
cat(length(files), "個のCSVを読み込みます\n")
############################################################
# 1ファイル読込
############################################################
read_gps <- function(file){
  cat("読込:", basename(file), "\n")
  df <- read_csv(
    file,
    show_col_types = FALSE
  )
  ##########################################################
  # 必須列チェック
  ##########################################################
  required <- c(
    "UUID",
    "Collecting time",
    "Longitude",
    "Latitude"
  )
  if(!all(required %in% names(df))){
    stop(
      paste(
        basename(file),
        "に必要な列がありません。"
      )
    )
  }
  ##########################################################
  # BirdID（UUID下4文字）
  ##########################################################
  df <- df %>%
    mutate(
      BirdID = str_to_lower(
        str_sub(UUID,-4)
      )
    )
  ##########################################################
  # UTC → 日本時間
  ##########################################################
  df <- df %>%
    mutate(
      DateTime = ymd_hms(
        `Collecting time`,
        tz="UTC"
      ),
      DateTime = with_tz(
        DateTime,
        "Asia/Tokyo"
      ),
      Date = as.Date(DateTime)
    )
  ##########################################################
  # 異常座標除去
  ##########################################################
  df <- df %>%
    filter(
      between(Longitude,-180,180),
      between(Latitude,-90,90)
    )
  ##########################################################
  # 必要列のみ返す
  ##########################################################
  df %>%
    select(
      BirdID,
      DateTime,
      Latitude,
      Longitude,
      Date
    )
}
############################################################
# 全CSV結合
############################################################
gps <- map_dfr(
  files,
  read_gps
)
############################################################
# 重複削除
############################################################
gps <- gps %>%
  distinct()
############################################################
# 並べ替え
############################################################
gps <- gps %>%
  arrange(
    BirdID,
    DateTime
  )
############################################################
# 各個体・各日最後の記録を採用
############################################################
gps <- gps %>%
  group_by(
    BirdID,
    Date
  ) %>%
  slice_tail(n=1) %>%
  ungroup()
############################################################
# 公開用CSV
############################################################
gps_public <- gps %>%
  transmute(
    BirdID,
    DateTime = format(
      DateTime,
      "%Y-%m-%d %H:%M"
    ),
    Latitude,
    Longitude
  ) %>%
  arrange(
    BirdID,
    DateTime
  )
############################################################
# 保存
############################################################
write_csv(
  gps_public,
  file.path(output_dir,"gps2.csv")
)
############################################################
# 完了
############################################################
cat("\n====================================\n")
cat("変換完了！\n")
cat("CSV数       :",length(files),"\n")
cat("レコード数  :",nrow(gps_public),"\n")
cat("保存先      :",file.path(output_dir,"gps2.csv"),"\n")
cat("====================================\n")
print(files)
