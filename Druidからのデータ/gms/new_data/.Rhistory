library(readr)
library(dplyr)
library(stringr)
library(lubridate)
library(purrr)
############################################################
# Druidデータフォルダ
############################################################
input_dir <- "."
############################################################
# 出力先
############################################################
output_file <- "C:/Users/ryuta/OneDrive/デスクトップ/BRコムクドリ渡りプロジェクト/KomukudoriLiveMap_new/Druidからのデータ/data/gms.csv"
############################################################
# CSV一覧取得
############################################################
files <- list.files(
  input_dir,
  pattern = "\\.csv$",
  full.names = TRUE
)
cat(length(files), "個のCSVを発見しました\n")
############################################################
# Druid CSV読込関数
############################################################
read_druid <- function(file){
  cat("読込:", basename(file), "\n")
  read_csv(
    file,
    col_types = cols(
      `Collection Time`       = col_character(),
      `Synchronized to Cloud` = col_character(),
      `Collected By`          = col_character(),
      Longitude = col_double(),
      Latitude  = col_double(),
      Confidence = col_guess(),
      Status     = col_guess()
    ),
    show_col_types = FALSE
  )
}
############################################################
# 全CSV結合
############################################################
gps <- map_dfr(files, read_druid)
############################################################
# BirdID（下4桁を4文字で保持）
############################################################
gps <- gps %>%
  mutate(
    BirdID = sprintf(
      "%04d",
      as.integer(str_sub(`Collected By`, -4))
    )
  )
############################################################
# UTC → 日本時間
############################################################
gps <- gps %>%
  mutate(
    DateTime = ymd_hms(
      `Collection Time`,
      tz = "UTC"
    ),
    DateTime = with_tz(
      DateTime,
      "Asia/Tokyo"
    ),
    Date = as.Date(DateTime)
  )
############################################################
# 座標欠損除去
############################################################
gps <- gps %>%
  filter(
    !is.na(Latitude),
    !is.na(Longitude)
  )
############################################################
# 重複削除
############################################################
gps <- gps %>%
  distinct()
############################################################
# 各個体・各日
# 最後の記録を採用
############################################################
gps <- gps %>%
  arrange(BirdID, DateTime) %>%
  group_by(BirdID, Date) %>%
  slice_tail(n = 1) %>%
  ungroup()
############################################################
# 公開用データ
############################################################
gps_public <- gps %>%
  transmute(
    BirdID,
    DateTime = format(
      DateTime,
      "%Y-%m-%d %H:%M"
    ),
    Latitude,
    Longitude
  ) %>%
  arrange(
    BirdID,
    DateTime
  )
############################################################
# 保存フォルダ作成
############################################################
dir.create(
  dirname(output_file),
  recursive = TRUE,
  showWarnings = FALSE
)
############################################################
# 保存
############################################################
write_csv(
  gps_public,
  output_file
)
############################################################
# 完了
############################################################
cat("\n============================\n")
cat("変換完了\n")
cat("CSV数 :", length(files), "\n")
cat("レコード数 :", nrow(gps_public), "\n")
cat("保存先 :", output_file, "\n")
cat("============================\n")
q()
