# Druid GPS(1400シリーズ専用)
# UUID形式 → gps2.csv
############################################################
library(readr)
library(dplyr)
library(stringr)
library(lubridate)
library(purrr)
############################################################
# フォルダ
############################################################
input_dir <- "C:/Users/ryuta/OneDrive/デスクトップ/BRコムクドリ渡りプロジェクト/KomukudoriLiveMap/Druidからのデータ/gps"
output_dir <- input_dir
############################################################
# CSV一覧
############################################################
files <- list.files(
  input_dir,
  pattern="\\.csv$",
  full.names=TRUE
)
cat(length(files),"個のCSVを発見\n")
############################################################
# 1ファイル読込
############################################################
read_gps <- function(file){
  cat("読込:",basename(file),"\n")
  df <- read_csv(
    file,
    show_col_types = FALSE
  )
  ##########################################################
  # UUID列がない（980形式）は無視
  ##########################################################
  if(!("UUID" %in% names(df))){
    message("980形式なのでスキップ")
    return(NULL)
  }
  ##########################################################
  # UUIDが空の行を除外
  ##########################################################
  df <- df %>%
    filter(!is.na(UUID))
  ##########################################################
  # UUIDが2cで始まるものだけ採用
  ##########################################################
  df <- df %>%
    filter(
      grepl("^2c",UUID)
    )
  ##########################################################
  # BirdID
  ##########################################################
  df <- df %>%
    mutate(
      BirdID = str_to_lower(
        str_sub(UUID,-4)
      )
    )
  ##########################################################
  # UTC→JST
  ##########################################################
  df <- df %>%
    mutate(
      DateTime = ymd_hms(
        `Collecting time`,
        tz="UTC"
      ),
      DateTime = with_tz(
        DateTime,
        "Asia/Tokyo"
      ),
      Date = as.Date(DateTime)
    )
  ##########################################################
  # 異常座標除去
  ##########################################################
  df <- df %>%
    filter(
      between(Longitude,-180,180),
      between(Latitude,-90,90)
    )
  ##########################################################
  # 必要列
  ##########################################################
  df %>%
    select(
      BirdID,
      DateTime,
      Latitude,
      Longitude,
      Date
    )
}
############################################################
# 全CSV結合
############################################################
gps <- map_dfr(
  files,
  read_gps
)
############################################################
# 重複削除
############################################################
gps <- gps %>%
  distinct()
############################################################
# 並べ替え
############################################################
gps <- gps %>%
  arrange(
    BirdID,
    DateTime
  )
############################################################
# 各日最後の位置
############################################################
gps <- gps %>%
  group_by(
    BirdID,
    Date
  ) %>%
  slice_tail(n=1) %>%
  ungroup()
############################################################
# 公開用形式
############################################################
gps2 <- gps %>%
  transmute(
    BirdID,
    DateTime = format(
      DateTime,
      "%Y-%m-%d %H:%M"
    ),
    Latitude,
    Longitude
  )
############################################################
# 保存
############################################################
write_csv(
  gps2,
  file.path(
    output_dir,
    "gps2.csv"
  )
)
############################################################
# 完了
############################################################
cat("\n==============================\n")
cat("変換完了！\n")
cat("CSV数 :",length(files),"\n")
cat("レコード数 :",nrow(gps2),"\n")
cat("保存 :",file.path(output_dir,"gps2.csv"),"\n")
cat("==============================\n")
library(readr)
library(dplyr)
library(stringr)
library(lubridate)
library(purrr)
############################################################
# Druidデータフォルダ
############################################################
input_dir <- "."
############################################################
# 出力先
############################################################
output_file <- "../data/gps.csv"
############################################################
# CSV一覧取得
############################################################
files <- list.files(
  input_dir,
  pattern = "\\.csv$",
  full.names = TRUE
)
cat(length(files), "個のCSVを発見しました\n")
############################################################
# Druid CSV読込関数
############################################################
read_druid <- function(file){
  cat("読込:", basename(file), "\n")
  read_csv(
    file,
    col_types = cols(
      `Collection Time`       = col_character(),
      `Synchronized to Cloud` = col_character(),
      `Collected By`          = col_character(),
      Longitude = col_double(),
      Latitude  = col_double(),
      Confidence = col_guess(),
      Status     = col_guess()
    ),
    show_col_types = FALSE
  )
}
############################################################
# 全CSV結合
############################################################
gps <- map_dfr(files, read_druid)
############################################################
# BirdID（下4桁を4文字で保持）
############################################################
gps <- gps %>%
  mutate(
    BirdID = sprintf(
      "%04d",
      as.integer(str_sub(`Collected By`, -4))
    )
  )
############################################################
# UTC → 日本時間
############################################################
gps <- gps %>%
  mutate(
    DateTime = ymd_hms(
      `Collection Time`,
      tz = "UTC"
    ),
    DateTime = with_tz(
      DateTime,
      "Asia/Tokyo"
    ),
    Date = as.Date(DateTime)
  )
############################################################
# 座標欠損除去
############################################################
gps <- gps %>%
  filter(
    !is.na(Latitude),
    !is.na(Longitude)
  )
############################################################
# 重複削除
############################################################
gps <- gps %>%
  distinct()
############################################################
# 各個体・各日
# 最後の記録を採用
############################################################
gps <- gps %>%
  arrange(BirdID, DateTime) %>%
  group_by(BirdID, Date) %>%
  slice_tail(n = 1) %>%
  ungroup()
############################################################
# 公開用データ
############################################################
gps_public <- gps %>%
  transmute(
    BirdID,
    DateTime = format(
      DateTime,
      "%Y-%m-%d %H:%M"
    ),
    Latitude,
    Longitude
  ) %>%
  arrange(
    BirdID,
    DateTime
  )
############################################################
# 保存
############################################################
write_csv(
  gps_public,
  output_file
)
############################################################
# 完了
############################################################
cat("\n============================\n")
cat("変換完了\n")
cat("CSV数 :", length(files), "\n")
cat("レコード数 :", nrow(gps_public), "\n")
cat("保存先 :", output_file, "\n")
cat("============================\n")
q()
