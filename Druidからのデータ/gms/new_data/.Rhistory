# 
座
標
欠
損
除
去
############################################################
gps <- gps %>%
  filter(
    !is.na(Latitude),
    !is.na(Longitude)
  )
############################################################
# 
重
複
削
除
############################################################
gps <- gps %>%
  distinct()
############################################################
# 
各
個
体
・
各
日
# 
最
後
の
記
録
を
採
用
############################################################
gps <- gps %>%
  arrange(BirdID, DateTime) %>%
  group_by(BirdID, Date) %>%
  slice_tail(n = 1) %>%
  ungroup()
############################################################
# 
公
開
用
デ
ー
タ
############################################################
gps_public <- gps %>%
  transmute(
    BirdID,
    DateTime = format(
      DateTime,
      "%Y-%m-%d %H:%M"
    ),
    Latitude,
    Longitude
  ) %>%
  arrange(
    BirdID,
    DateTime
  )
############################################################
# 
保
存
フ
ォ
ル
ダ
作
成
############################################################
dir.create(
  dirname(output_file),
  recursive = TRUE,
  showWarnings = FALSE
)
############################################################
# 
保
存
############################################################
write_csv(
  gps_public,
  output_file
)
############################################################
# 
完
了
############################################################
cat("\n============================\n")
cat("
変
換
完
了\n")
cat("CSV
数 :", length(files), "\n")
cat("
レ
コ
ー
ド
数 :", nrow(gps_public), "\n")
cat("
保
存
先 :", output_file, "\n")
cat("============================\n")
library(readr)
library(dplyr)
library(stringr)
library(lubridate)
library(purrr)
############################################################
# Druid
デ
ー
タ
フ
ォ
ル
ダ
############################################################
input_dir <- "."
############################################################
# 
出
力
先
############################################################
output_file <- "C:/Users/ryuta/OneDrive/
デ
ス
ク
ト
ッ
プ/BR
コ
ム
ク
ド
リ
渡
り
プ
ロ
ジ
ェ
ク
ト/KomukudoriLiveMap_new/Druid
か
ら
の
デ
ー
タ/data/gms.csv"
############################################################
# CSV
一
覧
取
得
############################################################
files <- list.files(
  input_dir,
  pattern = "\\.csv$",
  full.names = TRUE
)
cat(length(files), "
個
のCSV
を
発
見
し
ま
し
た\n")
############################################################
# Druid CSV
読
込
関
数
############################################################
read_druid <- function(file){
  cat("
読
込:", basename(file), "\n")
  read_csv(
    file,
    col_types = cols(
      `Collection Time`       = col_character(),
      `Synchronized to Cloud` = col_character(),
      `Collected By`          = col_character(),
      Longitude = col_double(),
      Latitude  = col_double(),
      Confidence = col_guess(),
      Status     = col_guess()
    ),
    show_col_types = FALSE
  )
}
############################################################
# 
全CSV
結
合
############################################################
gps <- map_dfr(files, read_druid)
############################################################
# BirdID
（
下4
桁
を4
文
字
で
保
持
）
############################################################
gps <- gps %>%
  mutate(
    BirdID = sprintf(
      "%04d",
      as.integer(str_sub(`Collected By`, -4))
    )
  )
############################################################
# UTC 
→ 
日
本
時
間
############################################################
gps <- gps %>%
  mutate(
    DateTime = ymd_hms(
      `Collection Time`,
      tz = "UTC"
    ),
    DateTime = with_tz(
      DateTime,
      "Asia/Tokyo"
    ),
    Date = as.Date(DateTime)
  )
############################################################
# 
座
標
欠
損
除
去
############################################################
gps <- gps %>%
  filter(
    !is.na(Latitude),
    !is.na(Longitude)
  )
############################################################
# 
重
複
削
除
############################################################
gps <- gps %>%
  distinct()
############################################################
# 
各
個
体
・
各
日
# 
最
後
の
記
録
を
採
用
############################################################
gps <- gps %>%
  arrange(BirdID, DateTime) %>%
  group_by(BirdID, Date) %>%
  slice_tail(n = 1) %>%
  ungroup()
############################################################
# 
公
開
用
デ
ー
タ
############################################################
gps_public <- gps %>%
  transmute(
    BirdID,
    DateTime = format(
      DateTime,
      "%Y-%m-%d %H:%M"
    ),
    Latitude,
    Longitude
  ) %>%
  arrange(
    BirdID,
    DateTime
  )
############################################################
# 
保
存
フ
ォ
ル
ダ
作
成
############################################################
dir.create(
  dirname(output_file),
  recursive = TRUE,
  showWarnings = FALSE
)
############################################################
# 
保
存
############################################################
write_csv(
  gps_public,
  output_file
)
############################################################
# 
完
了
############################################################
cat("\n============================\n")
cat("
変
換
完
了\n")
cat("CSV
数 :", length(files), "\n")
cat("
レ
コ
ー
ド
数 :", nrow(gps_public), "\n")
cat("
保
存
先 :", output_file, "\n")
cat("============================\n")
